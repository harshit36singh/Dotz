# Copy this file to .env (flutter_dotenv loads .env as an app asset, see pubspec.yaml).
#
# zenquotes.io is a free, public, unauthenticated endpoint, so the default value below
# is safe to keep in this example file. If you ever switch to a paid/keyed quote API,
# do NOT commit the real value — keep it only in your local .env (gitignored) and inject
# it via a CI secret instead.
QUOTE_API_URL=https://zenquotes.io/api/today
